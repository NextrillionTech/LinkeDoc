datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  DOCTOR
  NURSE
  PHARMACIST
  RESEARCHER
  RECRUITER
  ADMIN
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ReportContentType {
  THREAD
  REPLY
}

enum ReportStatus {
  PENDING
  RESOLVED
}

model User {
  id            String             @id @default(uuid())
  name          String
  email         String             @unique
  passwordHash  String
  role          Role
  specialty     String?
  licenseNumber String?
  education     Json?              // Array of degrees, schools, years
  experience    Json?              // Array of jobs, companies, years
  skills        String[]           // Array of strings
  status        Status             @default(PENDING)
  publicKey     String?            // E2EE public key
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // Connections
  connectionsSent     Connection[] @relation("requester")
  connectionsReceived Connection[] @relation("receiver")

  // Forum activity
  threads             DiscussionThread[]
  replies             PostReply[]

  // Jobs posted
  jobs                JobListing[]

  // Reports submitted
  reports             Report[]

  // Conversations & Messages (E2EE direct messaging)
  conversationsAsP1   Conversation[]     @relation("participant1")
  conversationsAsP2   Conversation[]     @relation("participant2")
  messagesSent        Message[]          @relation("messageSender")
}

model Connection {
  id          String           @id @default(uuid())
  requesterId String
  receiverId  String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  requester   User             @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User             @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model ForumCategory {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  slug        String             @unique
  threads     DiscussionThread[]
}

model DiscussionThread {
  id          String          @id @default(uuid())
  categoryId  String
  authorId    String
  title       String
  body        String
  status      Status          @default(APPROVED) // APPROVED maps to active state, HIDDEN/PENDING maps to hidden state
  createdAt   DateTime        @default(now())

  category    ForumCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author      User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies     PostReply[]
}

model PostReply {
  id          String           @id @default(uuid())
  threadId    String
  authorId    String
  body        String
  status      Status           @default(APPROVED)
  createdAt   DateTime         @default(now())

  thread      DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author      User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model JobListing {
  id          String   @id @default(uuid())
  recruiterId String
  title       String
  description String
  specialty   String
  location    String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  recruiter   User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
}

model Report {
  id          String            @id @default(uuid())
  reporterId  String
  contentType ReportContentType
  contentId   String
  reason      String
  status      ReportStatus      @default(PENDING)
  createdAt   DateTime          @default(now())

  reporter    User              @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}

model Conversation {
  id             String    @id @default(uuid())
  participant1Id String
  participant2Id String
  createdAt      DateTime  @default(now())
  
  messages       Message[]

  participant1   User      @relation("participant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2   User      @relation("participant2", fields: [participant2Id], references: [id], onDelete: Cascade)

  @@unique([participant1Id, participant2Id])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  encryptedBody  String       // Base64 encoded ciphertext
  status         String       @default("SENT") // SENT, READ
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("messageSender", fields: [senderId], references: [id], onDelete: Cascade)
}
