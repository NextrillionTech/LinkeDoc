datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  DOCTOR
  NURSE
  PHARMACIST
  RESEARCHER
  RECRUITER
  ADMIN
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ReportContentType {
  THREAD
  REPLY
}

enum ReportStatus {
  PENDING
  RESOLVED
}

model User {
  id            String             @id @default(uuid())
  name          String
  email         String             @unique
  passwordHash  String
  role          Role
  specialty     String?
  licenseNumber String?
  education     Json?              // Array of degrees, schools, years
  experience    Json?              // Array of jobs, companies, years
  skills        String[]           // Array of strings
  status        Status             @default(PENDING)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // Connections
  connectionsSent     Connection[] @relation("requester")
  connectionsReceived Connection[] @relation("receiver")

  // Forum activity
  threads             DiscussionThread[]
  replies             PostReply[]

  // Jobs posted
  jobs                JobListing[]

  // Reports submitted
  reports             Report[]
}

model Connection {
  id          String           @id @default(uuid())
  requesterId String
  receiverId  String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  requester   User             @relation("requester", fields: [requesterId], onDelete: Cascade)
  receiver    User             @relation("receiver", fields: [receiverId], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model ForumCategory {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  slug        String             @unique
  threads     DiscussionThread[]
}

model DiscussionThread {
  id          String          @id @default(uuid())
  categoryId  String
  authorId    String
  title       String
  body        String
  status      Status          @default(APPROVED) // APPROVED maps to active state, HIDDEN/PENDING maps to hidden state
  createdAt   DateTime        @default(now())

  category    ForumCategory   @relation(fields: [categoryId], onDelete: Cascade)
  author      User            @relation(fields: [authorId], onDelete: Cascade)
  replies     PostReply[]
}

model PostReply {
  id          String           @id @default(uuid())
  threadId    String
  authorId    String
  body        String
  status      Status           @default(APPROVED)
  createdAt   DateTime         @default(now())

  thread      DiscussionThread @relation(fields: [threadId], onDelete: Cascade)
  author      User             @relation(fields: [authorId], onDelete: Cascade)
}

model JobListing {
  id          String   @id @default(uuid())
  recruiterId String
  title       String
  description String
  specialty   String
  location    String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  recruiter   User     @relation(fields: [recruiterId], onDelete: Cascade)
}

model Report {
  id          String            @id @default(uuid())
  reporterId  String
  contentType ReportContentType
  contentId   String
  reason      String
  status      ReportStatus      @default(PENDING)
  createdAt   DateTime          @default(now())

  reporter    User              @relation(fields: [reporterId], onDelete: Cascade)
}
